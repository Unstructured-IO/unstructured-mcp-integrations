# Your Anthropic API key — powers the chat model (Claude).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Your Unstructured Transform API key — authenticates the Transform MCP server.
# Get one at https://transform.unstructured.io/get-started
# NOTE: this is a Transform key, which is distinct from a Platform API key.
UNSTRUCTURED_API_KEY=...

# Optional: override the Transform MCP endpoint (defaults to production root).
# UNSTRUCTURED_MCP_URL=https://mcp.transform.unstructured.io
